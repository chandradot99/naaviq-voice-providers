DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/naaviq

# Provider API keys — used by sync scripts
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
GOOGLE_CLOUD_API_KEY=
SARVAM_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
HUME_API_KEY=
INWORLD_API_KEY=

# AI parser key — used by sync scripts that parse docs (e.g., Cartesia models)
ANTHROPIC_API_KEY=

# AI parser model — defaults to Haiku (cheap, fast). Set to claude-sonnet-4-6 in prod.
# NAAVIQ_AI_PARSER_MODEL=claude-sonnet-4-6
